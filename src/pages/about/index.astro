---
import { Button, Collapse, Spoiler, Timeline } from 'astro-pure/user'
import PageLayout from '@/layouts/CommonPage.astro'
import Substats from '@/components/about/Substats.astro'
import ToolSection from '@/components/about/ToolSection.astro'

const headings = [
  { depth: 2, slug: 'intro', text: '简介' },
  { depth: 2, slug: 'hobbies', text: '兴趣爱好' },
  { depth: 2, slug: 'tools', text: '工具箱' },
  { depth: 2, slug: 'social-networks', text: '社交账号' },
  { depth: 2, slug: 'gossips', text: '碎碎念' },
  { depth: 2, slug: 'about-blog', text: '关于博客' }
]
---

<PageLayout title='关于' {headings} comment>
  <p>Developer / 观察者 / 御坂爱好者</p>
  
  <p>
    你好，我是 <strong>Rainight</strong>（也写作 SkyRain），一个喜欢在代码和文字间游走的开发者。
    目前就读于 <strong>燕山大学 (YSU)</strong>，常驻中国大陆。
  </p>
  
  <p>
    我的 GitHub 签名是：「<em>是那个叫茵什么克丝的小姐吗？</em>」——如果你也看懂了，那我们可能是同类人。
    <Spoiler>对，就是那个会放电的萝莉！</Spoiler>
  </p>
  
  <p>
    你可以通过邮件联系到我：<a href="mailto:admin@misakacloud.net">admin@misakacloud.net</a>
  </p>
  
  <Button title='GitHub Profile' class='w-fit' href='https://github.com/KamijoToma' variant='ahead' />

  {/* hobbies */}
  <h2 id='hobbies'>兴趣爱好</h2>
  <ul>
    <li>🎮 游戏：Galgame、Steam 独立游戏、偶尔玩点竞技</li>
    <li>📺 动画：轻小说改、日常系、偶尔追番</li>
    <li>💻 技术：Web 开发、云服务、折腾各种新玩具</li>
    <li>☁️ 云原生：Cloudflare、VPS、自建服务爱好者</li>
    <li>📝 写作：技术笔记、生活随笔、偶尔写点小说</li>
  </ul>

  {/* tools */}
  <h2 id='tools'>工具箱</h2>
  <p>目前主要使用的工具：</p>
  <ToolSection
    class='mb-5'
    title='开发'
    tools={[
      {
        name: 'VS Code',
        description: '主力编辑器',
        href: 'https://code.visualstudio.com/',
        icon: import('@/assets/tools/vscode.svg?raw')
      },
      {
        name: 'Neovim',
        description: '终端编辑器',
        href: 'https://neovim.io/',
        icon: import('@/assets/tools/neovim.svg?raw')
      }
    ]}
  />
  <ToolSection
    class='mb-5'
    title='系统'
    tools={[
      {
        name: 'Arch Linux',
        description: '主力系统',
        href: 'https://archlinux.org/',
        icon: import('@/assets/tools/archlinux.svg?raw')
      },
      {
        name: 'Windows 11',
        description: '备用系统',
        href: 'https://microsoft.com/windows',
        icon: import('@/assets/tools/windows11.svg?raw')
      },
      {
        name: 'macOS',
        description: '偶尔使用',
        href: 'https://apple.com/macos/',
        icon: import('@/assets/tools/apple.svg?raw')
      }
    ]}
  />
  <ToolSection
    class='mb-5'
    title='生产力'
    tools={[
      {
        name: 'Notion',
        description: '项目管理',
        href: 'https://notion.so/',
        icon: import('@/assets/tools/notion.svg?raw')
      },
      {
        name: 'Chrome',
        description: '主力浏览器',
        href: 'https://google.com/chrome/',
        icon: import('@/assets/tools/chrome.svg?raw')
      }
    ]}
  />

  {/* social-networks */}
  <h2 id='social-networks'>社交账号</h2>
  <p>
    欢迎关注我，或者直接通过 Telegram 联系。我喜欢和有趣的人交流技术、游戏和动画。
  </p>
  <Substats
    stats={[
      {
        platform: 'GitHub',
        icon: 'github',
        link: 'https://github.com/KamijoToma',
        text: 'followers',
        api: 'github/KamijoToma'
      },
      {
        platform: 'Telegram',
        icon: 'telegram',
        color: '#2ca5e0',
        link: 'https://t.me/fc90d',
        text: '频道',
        api: ''
      },
      {
        platform: 'Email',
        icon: 'email',
        color: '#ea4335',
        link: 'mailto:admin@misakacloud.net',
        text: '联系我',
        api: ''
      }
    ]}
  />

  {/* gossips */}
  <h2 id='gossips'>碎碎念</h2>
  <Collapse title='为什么叫 Rainight？'>
    Rain + night = Rainight。喜欢在雨夜写代码的感觉，安静而专注。
    也谐音 "Right"，希望做的每个决定都是正确的。
  </Collapse>
  <Collapse title='关于头像'>
    如果你认出了我的头像，那你一定知道「某科学的超电磁炮」。
    御坂美琴是我最喜欢的动漫角色，没有之一。
  </Collapse>
  <Collapse title='技术理念'>
    追求简洁优雅的解决方案。能用静态的不用动态，能自托管的不依赖第三方。
    相信好的技术应该像空气一样——无处不在却感觉不到它的存在。
  </Collapse>

  {/* about-blog */}
  <h2 id='about-blog'>关于博客</h2>
  <p>博客演进历程：</p>
  <Timeline
    events={[
      {
        date: '2024',
        content: '开始认真写技术博客，记录学习过程中的坑和心得'
      },
      {
        date: '2025-03',
        content: '从 Hexo 迁移到 <a href="https://astro.build/" target="_blank">Astro</a>，使用 <a href="https://github.com/cworld1/astro-theme-pure" target="_blank">Pure 主题</a>'
      },
      {
        date: '2025-03-22',
        content: '部署到 <a href="https://cloudflare.com" target="_blank">Cloudflare Pages</a>，自建评论系统上线'
      }
    ]}
  />
  <p>
    本博客的顺利运行离不开以下优秀项目和服务商：
  </p>
  <ul>
    <li>框架：<a href='https://astro.build/' target='_blank'>Astro</a></li>
    <li>主题：<a href='https://github.com/cworld1/astro-theme-pure' target='_blank'>Astro Theme Pure</a></li>
    <li>托管：<a href='https://cloudflare.com/' target='_blank'>Cloudflare Pages</a></li>
    <li>评论：自建系统 (Cloudflare D1 + Functions)</li>
    <li>统计：<a href='https://github.com/spencerwooo/substats' target='_blank'>Substats</a></li>
  </ul>
</PageLayout>
