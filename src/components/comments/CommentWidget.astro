---
interface Props {
  slug: string
  path: string
}

const { slug, path } = Astro.props
---

<div class="comment-widget mt-16 pt-8 border-t border-gray-200 dark:border-gray-800">
  <h3 class="text-xl font-semibold mb-6">评论</h3>
  
  <!-- Comment List -->
  <div id="comment-list" class="space-y-4 mb-8" data-slug={slug}>
    <p class="text-gray-500 text-sm">加载中...</p>
  </div>
  
  <!-- Comment Form -->
  <form id="comment-form" class="space-y-4" data-slug={slug} data-path={path}>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <input 
        type="text" 
        name="author_name" 
        placeholder="昵称 *" 
        required
        maxlength="50"
        class="px-4 py-2 border rounded-lg dark:bg-gray-800 dark:border-gray-700 focus:ring-2 focus:ring-blue-500"
      />
      <input 
        type="email" 
        name="author_email" 
        placeholder="邮箱（保密，用于头像）"
        maxlength="100"
        class="px-4 py-2 border rounded-lg dark:bg-gray-800 dark:border-gray-700 focus:ring-2 focus:ring-blue-500"
      />
    </div>
    <input 
      type="url" 
      name="author_url" 
      placeholder="个人网站（可选）"
      maxlength="255"
      class="w-full px-4 py-2 border rounded-lg dark:bg-gray-800 dark:border-gray-700 focus:ring-2 focus:ring-blue-500"
    />
    <textarea 
      name="content" 
      placeholder="写下你的评论... *"
      required
      maxlength="5000"
      rows="4"
      class="w-full px-4 py-2 border rounded-lg dark:bg-gray-800 dark:border-gray-700 focus:ring-2 focus:ring-blue-500 resize-vertical"
    ></textarea>
    
    <!-- Turnstile placeholder -->
    <div class="cf-turnstile" data-sitekey={import.meta.env.PUBLIC_TURNSTILE_SITE_KEY || ''}></div>
    
    <button 
      type="submit" 
      class="px-6 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
    >
      提交评论
    </button>
    
    <p class="text-xs text-gray-500">
      评论需要审核后显示。支持 Markdown 格式。
    </p>
  </form>
</div>

<script>
  // Load comments
  async function loadComments() {
    const listEl = document.getElementById('comment-list')
    const slug = listEl?.dataset.slug
    if (!slug) return
    
    try {
      const res = await fetch(`/api/comments?slug=${encodeURIComponent(slug)}`)
      const data = await res.json() as { comments?: any[] }
      
      if (!data.comments || data.comments.length === 0) {
        listEl.innerHTML = '<p class="text-gray-500 text-sm">暂无评论，来发表第一条吧！</p>'
        return
      }
      
      listEl.innerHTML = data.comments.map((c) => `
        <div class="comment-item p-4 bg-gray-50 dark:bg-gray-900 rounded-lg ${c.parent_id ? 'ml-8 mt-2' : ''}">
          <div class="flex items-center gap-2 mb-2">
            <span class="font-medium">${escapeHtml(c.author_name)}</span>
            ${c.author_url ? `<a href="${escapeHtml(c.author_url)}" target="_blank" rel="nofollow" class="text-gray-400 hover:text-blue-500">↗</a>` : ''}
            <span class="text-gray-400 text-xs">${new Date(c.created_at).toLocaleString('zh-CN')}</span>
          </div>
          <div class="prose dark:prose-invert max-w-none text-sm">${escapeHtml(c.content)}</div>
        </div>
      `).join('')
    } catch (err) {
      listEl.innerHTML = '<p class="text-red-500 text-sm">加载评论失败，请刷新重试</p>'
    }
  }
  
  // Escape HTML to prevent XSS
  function escapeHtml(text: string): string {
    const div = document.createElement('div')
    div.textContent = text
    return div.innerHTML
  }
  
  // Submit comment
  const form = document.getElementById('comment-form') as HTMLFormElement
  form?.addEventListener('submit', async (e) => {
    e.preventDefault()
    const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement
    btn.disabled = true
    btn.textContent = '提交中...'
    
    try {
      const formData = new FormData(form)
      const turnstileToken = form.querySelector('[name="cf-turnstile-response"]')?.getAttribute('value')
      
      const res = await fetch('/api/comments', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          slug: form.dataset.slug,
          path: form.dataset.path,
          author_name: formData.get('author_name'),
          author_email: formData.get('author_email'),
          author_url: formData.get('author_url'),
          content: formData.get('content'),
          turnstile_token: turnstileToken
        })
      })
      
      const data = await res.json() as { success?: boolean; error?: string }
      
      if (data.success) {
        alert('评论已提交，审核通过后显示')
        form.reset()
        loadComments()
      } else {
        alert(data.error || '提交失败')
      }
    } catch (err) {
      alert('网络错误，请重试')
    } finally {
      btn.disabled = false
      btn.textContent = '提交评论'
    }
  })
  
  // Load comments on mount
  loadComments()
</script>

{/* Load Turnstile script */}
<script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
